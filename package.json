{
  "name": "papra-email-proxy",
  "type": "module",
  "version": "1.0.3",
  "packageManager": "pnpm@9.15.9",
  "description": "Cloudflare Email Worker that forwards inbound mail to Papra, with optional Cloudflare Zero Trust (Access) service-token support for protected origins",
  "author": "Corentin Thomasset <corentinth@proton.me> (https://corentin.tech)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/papra-hq/email-proxy"
  },
  "bugs": {
    "url": "https://github.com/papra-hq/email-proxy/issues"
  },
  "keywords": [
    "email",
    "proxy",
    "papra",
    "document",
    "ingestion",
    "cloudflare",
    "workers",
    "zero-trust",
    "cloudflare-access",
    "service-token"
  ],
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "typecheck": "tsc --noEmit",
    "build": "wrangler build",
    "release": "bumpp --commit --tag --push"
  },
  "dependencies": {
    "@crowlog/logger": "^2.2.2",
    "@owlrelay/webhook": "^0.0.3",
    "postal-mime": "^2.7.5"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.4",
    "@cloudflare/workers-types": "^5.20260717.1",
    "bumpp": "^11.1.0",
    "typescript": "^7.0.2",
    "wrangler": "^4.112.0"
  }
}
